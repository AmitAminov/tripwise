# Copy this to .env.local and fill in real values from your Supabase project.
# Get these from https://app.supabase.com → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Site URL — used in magic-link emails for the redirect.
# Local: http://localhost:3000
# Prod:  https://your-domain.example
NEXT_PUBLIC_SITE_URL=http://localhost:3000
