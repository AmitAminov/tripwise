# Copy this to .env.local and fill in real values.
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.

# ------- Supabase -------
# Get these from https://app.supabase.com → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Used in magic-link emails for the redirect.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------- Flights (fast-flights microservice) -------
# The Python FastAPI service in python-services/flights runs the
# fast-flights (AWeirdDev/flights) library. Run it locally with:
#   cd python-services/flights
#   uvicorn main:app --port 8001 --reload
FAST_FLIGHTS_BASE_URL=http://localhost:8001

# ------- Google Cloud (Places / Routes / Maps JS / Geocoding) -------
# One Cloud API key covers all four APIs. Enable them in Cloud Console.
# The NEXT_PUBLIC_ variant is embedded in the Maps JS SDK; restrict it
# to HTTP referrers on your domain(s).
GOOGLE_MAPS_API_KEY=AIza_your_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_your_key

# ------- Gemini (text — day-planner; image gen requires paid tier) -------
# Get from https://aistudio.google.com/apikey — separate from the Cloud
# Maps key. Text generation (gemini-2.5-flash) works on the free tier;
# image gen (Nano Banana / gemini-2.5-flash-image, Imagen 4) needs the
# Tier 1 upgrade at https://aistudio.google.com/plan.
GEMINI_API_KEY=AIza_your_ai_studio_key

# ------- Google Calendar export -------
# OAuth 2.0 Client ID + Secret (Web application type, redirect URI
# http://localhost:3000/api/google/callback).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ------- Events (PredictHQ preferred; Ticketmaster optional) -------
# PredictHQ — https://control.predicthq.com/settings/api-keys
# Bearer token; free tier covers the demo. Composite provider merges
# this with the curated seed and dedupes.
PREDICTHQ_API_KEY=your_predicthq_bearer_token

# Optional secondary source: Ticketmaster Discovery API, free-tier
# TICKETMASTER_API_KEY=

# ------- Hotel inventory (LiteAPI) -------
# Partner-approved inventory API — sandbox keys prefix "sand_"
# https://liteapi.travel — dashboard → API keys
LITEAPI_API_KEY=sand_your_liteapi_sandbox_key
